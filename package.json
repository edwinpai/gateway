{
  "name": "@edwinpai/edwinpai",
  "version": "1.0.0-beta.2",
  "private": false,
  "description": "EdwinPAI — Personal AI agent framework with cryptographic security",
  "keywords": [],
  "license": "BSL-1.1",
  "author": "",
  "bin": {
    "edwinpai": "edwinpai.mjs"
  },
  "files": [
    "dist/",
    "edwinpai.mjs",
    "LICENSE",
    "README.md",
    "README-header.png"
  ],
  "type": "module",
  "main": "dist/index.js",
  "typesVersions": {
    "*": {
      "plugin-sdk": [
        "src/plugin-sdk/index.ts"
      ],
      "*": [
        "dist/*"
      ]
    }
  },
  "exports": {
    ".": "./dist/index.js",
    "./cli-entry": "./edwinpai.mjs"
  },
  "scripts": {
    "build": "tsdown",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@edwinpai/identity-core": "1.0.0-beta.2",
    "@edwinpai/shad-core": "1.0.0-beta.2"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "tsdown": "^0.20.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "tar": "7.5.8"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.23.0",
  "pnpm": {
    "minimumReleaseAge": 2880,
    "overrides": {
      "fast-xml-parser": "5.3.4",
      "form-data": "2.5.4",
      "@hono/node-server>hono": "4.11.7",
      "hono": "4.11.7",
      "qs": "6.14.1",
      "@sinclair/typebox": "0.34.47",
      "tar": "7.5.8",
      "tough-cookie": "4.1.3"
    },
    "onlyBuiltDependencies": [
      "@lydell/node-pty",
      "@matrix-org/matrix-sdk-crypto-nodejs",
      "@napi-rs/canvas",
      "@whiskeysockets/baileys",
      "authenticate-pam",
      "esbuild",
      "node-llama-cpp",
      "protobufjs",
      "sharp"
    ]
  },
  "vitest": {
    "coverage": {
      "provider": "v8",
      "reporter": [
        "text",
        "lcov"
      ],
      "thresholds": {
        "lines": 70,
        "functions": 70,
        "branches": 70,
        "statements": 70
      },
      "include": [
        "src/**/*.ts"
      ],
      "exclude": [
        "src/**/*.test.ts"
      ]
    },
    "include": [
      "src/**/*.test.ts"
    ],
    "exclude": [
      "dist/**",
      "**/vendor/**",
      "dist/EdwinPAI.app/**"
    ]
  },
  "publishConfig": {
    "access": "restricted",
    "tag": "beta"
  }
}
